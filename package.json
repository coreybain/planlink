{
  "name": "planlink",
  "version": "0.1.4",
  "description": "Static HTML draft publishing for agents.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "homepage": "https://github.com/coreybain/planlink#readme",
  "bugs": {
    "url": "https://github.com/coreybain/planlink/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coreybain/planlink.git"
  },
  "keywords": [
    "agents",
    "drafts",
    "html",
    "publishing",
    "plans",
    "static"
  ],
  "bin": {
    "planlink": "dist/bin/planlink.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun --watch src/server.ts",
    "start": "bun dist/server.js",
    "cli": "bun src/bin/planlink.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "bun test test/*.test.ts"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.835.0",
    "commander": "^14.0.0",
    "express": "^5.1.0",
    "nanoid": "^5.1.5",
    "parse5": "^7.3.0",
    "pg": "^8.16.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.4",
    "@types/pg": "^8.15.4",
    "typescript": "^5.8.3"
  }
}
